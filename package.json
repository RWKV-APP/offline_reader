{
  "name": "rwkv-offline-reader",
  "version": "0.5.0",
  "description": "Chrome extension for local RWKV webpage translation",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "clean:bundle": "rimraf dist && turbo clean:bundle",
    "clean:node_modules": "pnpx rimraf node_modules && pnpx turbo clean:node_modules",
    "clean:turbo": "rimraf .turbo && turbo clean:turbo",
    "clean": "pnpm clean:bundle && pnpm clean:turbo && pnpm clean:node_modules",
    "clean:install": "pnpm clean:node_modules && pnpm install --frozen-lockfile",
    "prepare-env": "pnpm copy-env && pnpm set-global-env",
    "prepare-env:dev": "pnpm copy-env && pnpm set-global-env CLI_CEB_DEV=true",
    "type-check": "pnpm prepare-env && turbo type-check --filter=chrome-extension --filter=@extension/popup --filter=@extension/content-script --filter=@extension/content-ui",
    "base-build": "pnpm clean:bundle && turbo build --filter=chrome-extension --filter=@extension/popup --filter=@extension/content-script --filter=@extension/content-ui",
    "build": "pnpm prepare-env && pnpm base-build",
    "base-dev": "pnpm clean:bundle && turbo ready --filter=@extension/hmr --filter=chrome-extension --filter=@extension/popup --filter=@extension/content-script --filter=@extension/content-ui && turbo watch dev --filter=@extension/hmr --filter=chrome-extension --filter=@extension/popup --filter=@extension/content-script --filter=@extension/content-ui",
    "dev": "pnpm prepare-env:dev && pnpm base-dev",
    "zip": "pnpm build && pnpm -F zipper zip",
    "lint": "pnpm prepare-env && turbo lint --filter=chrome-extension --filter=@extension/popup --filter=@extension/content-script --filter=@extension/content-ui --continue",
    "lint:fix": "turbo lint:fix --continue",
    "format": "turbo format --continue -- --cache --cache-location node_modules/.cache/.prettiercache",
    "check": "pnpm type-check && pnpm lint",
    "prepare": "husky",
    "update-version": "bash bash-scripts/update_version.sh",
    "copy-env": "bash bash-scripts/copy_env.sh",
    "set-global-env": "bash bash-scripts/set_global_env.sh",
    "postinstall": "pnpm copy-env"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.0.323",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.60.1",
    "autoprefixer": "^10.5.0",
    "cross-env": "^7.0.3",
    "deepmerge": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.3",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rimraf": "^6.1.3",
    "run-script-os": "^1.1.6",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.4.3",
    "vite-plugin-node-polyfills": "^0.24.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.15.1"
  }
}
